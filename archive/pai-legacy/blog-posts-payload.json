                "decorations": []
              }
            }],
            "paragraphData": {}
          }
        ]
      },
      "categoryIds": [],
      "tagIds": []
    },
    {
      "title": "What to include on a candidate landing page",
      "memberId": "abce5218-72ad-4ab3-9b93-2ee0c0649248",
      "richContent": {
        "nodes": [
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Role description, application form, and company context that converts visitors to applicants.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "A dedicated landing page for each role converts better than a generic careers page. Here's what to include.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "HEADING",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Clear Role Description",
                "decorations": []
              }
            }],
            "headingData": {
              "level": 2
            }
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Lead with what the candidate will actually do, not generic responsibilities. Be specific about projects and outcomes.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "HEADING",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Company Context",
                "decorations": []
              }
            }],
            "headingData": {
              "level": 2
            }
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Tell candidates why the company exists, what stage you're at, and what success looks like. This filters for cultural fit.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "HEADING",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Application Form",
                "decorations": []
              }
            }],
            "headingData": {
              "level": 2
            }
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Keep it short. Name, email, LinkedIn, and one or two role-specific questions. Long forms kill conversion.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          }
        ]
      },
      "categoryIds": [],
      "tagIds": []
    },
    {
      "title": "How to coordinate hiring across Slack without losing candidates",
      "memberId": "abce5218-72ad-4ab3-9b93-2ee0c0649248",
      "richContent": {
        "nodes": [
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Pipeline updates, reminders, and team coordination patterns that work.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Slack can be a great hiring coordination tool, but only if you set up the right patterns. Here's how to avoid chaos.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "HEADING",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Create a Dedicated Channel",
                "decorations": []
              }
            }],
            "headingData": {
              "level": 2
            }
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Don't mix hiring discussions with general chatter. A dedicated #hiring channel keeps everything in one place.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "HEADING",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Use Threads for Each Candidate",
                "decorations": []
              }
            }],
            "headingData": {
              "level": 2
            }
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Post a parent message for each candidate with their name and role. All discussion happens in the thread. This keeps the channel scannable.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          },
          {
            "type": "HEADING",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Automate Status Updates",
                "decorations": []
              }
            }],
            "headingData": {
              "level": 2
            }
          },
          {
            "type": "PARAGRAPH",
            "nodes": [{
              "type": "TEXT",
              "textData": {
                "text": "Use Zapier or similar tools to post to Slack when candidates move stages in your ATS. This keeps everyone informed without manual updates.",
                "decorations": []
              }
            }],
            "paragraphData": {}
          }
        ]
      },
      "categoryIds": [],
      "tagIds": []
    },
