# =====================================================
# AI SECURITY RECRUITMENT PLATFORM - ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control (add to .gitignore)

# =====================================================
# SUPABASE DATABASE
# =====================================================
# Get these from your Supabase project settings:
# https://app.supabase.com/project/{your-project}/settings/api

# Supabase Project URL
# Example: https://xyzcompany.supabase.co
SUPABASE_URL=your_supabase_project_url

# Supabase Anonymous/Public Key (safe for client-side)
# Used for public API access with RLS enabled
SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (server-side only - has full access)
# WARNING: Keep this secret! Bypasses RLS policies
SUPABASE_SERVICE_KEY=your_supabase_service_key

# =====================================================
# APPLICATION SETTINGS
# =====================================================

# Application environment
# Options: development, staging, production
NODE_ENV=development

# Server port (for local development)
PORT=3000

# =====================================================
# LLM API KEYS (for future agents)
# =====================================================

# Anthropic Claude API Key (for reasoning tasks)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key

# Ollama Base URL (for local enrichment with Mistral)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# =====================================================
# RSS FEED CONFIGURATION (for future RSS aggregator)
# =====================================================

# RSS feed poll interval (minutes)
RSS_POLL_INTERVAL=60

# RSS feed sources (comma-separated URLs)
# Example: https://techcrunch.com/feed/,https://venturebeat.com/feed/
RSS_FEED_URLS=

# =====================================================
# ATTIO CRM INTEGRATION (for future sync)
# =====================================================

# Attio API Key
# Get from: https://app.attio.com/settings/api
ATTIO_API_KEY=your_attio_api_key

# Attio Workspace ID
ATTIO_WORKSPACE_ID=your_attio_workspace_id

# Sync frequency (hours)
ATTIO_SYNC_INTERVAL=24

# =====================================================
# FILE STORAGE (for CSV uploads and resume storage)
# =====================================================

# Storage provider: local, s3, supabase
STORAGE_PROVIDER=local

# Local storage path (for development)
UPLOAD_DIR=./uploads

# AWS S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# =====================================================
# LOGGING & MONITORING
# =====================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, pretty
LOG_FORMAT=pretty

# =====================================================
# SECURITY
# =====================================================

# JWT Secret (for authentication)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# =====================================================
# RATE LIMITING
# =====================================================

# Max requests per IP per window
RATE_LIMIT_MAX=100

# Rate limit window (minutes)
RATE_LIMIT_WINDOW=15

# =====================================================
# FEATURE FLAGS
# =====================================================

# Enable agent auto-enrichment
ENABLE_AUTO_ENRICHMENT=false

# Enable feedback learning loop
ENABLE_FEEDBACK_LOOP=false

# Enable Attio sync
ENABLE_ATTIO_SYNC=false

# =====================================================
# DEVELOPMENT TOOLS
# =====================================================

# Enable debug mode (verbose logging)
DEBUG=false

# Enable database query logging
DB_QUERY_LOG=false

# Seed database with test data on startup
SEED_TEST_DATA=false
