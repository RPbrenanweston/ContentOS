# ============================================================
# FreeFlow Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── OpenAI API Key (required) ──
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ── Realtime model (optional — defaults shown) ──
# gpt-4o-realtime-preview  = best quality (~$0.007/dictation)
# gpt-realtime-mini        = cheaper (~$0.002/dictation)
REALTIME_MODEL=gpt-4o-realtime-preview
POLISH_MODEL=gpt-4.1-nano

# ── PostgreSQL ──
POSTGRES_USER=freeflow
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=freeflow

# ── Auth secrets ──
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND
BOOTSTRAP_TOKEN=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND

# ── Public URL (your domain with https) ──
PUBLIC_URL=https://freeflow.yourdomain.com
