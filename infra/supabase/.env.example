# ============================================================
# Self-Hosted Supabase — Environment Variables
# ============================================================
# Copy to .env and fill in values:
#   cp .env.example .env
#
# Generate secrets with:
#   ../scripts/generate-keys.sh
# ============================================================

# ── JWT Secret (REQUIRED — shared across all services) ──
# Generate: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters
JWT_EXP=3600

# ── Generated JWT Keys (use generate-keys.sh) ──
ANON_KEY=eyJ...your-generated-anon-key
SERVICE_ROLE_KEY=eyJ...your-generated-service-role-key

# ── PostgreSQL ──
POSTGRES_PASSWORD=your-strong-database-password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── URLs ──
API_EXTERNAL_URL=http://localhost:8000
SITE_URL=http://localhost:3000

# ── Ports ──
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
STUDIO_PORT=3001

# ── Auth Settings ──
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ADDITIONAL_REDIRECT_URLS=http://localhost:3000,http://localhost:3100

# ── OAuth Providers (for Content OS distribution) ──

# LinkedIn
ENABLE_LINKEDIN=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter/X
ENABLE_TWITTER=false
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Google (calendar sync)
ENABLE_GOOGLE=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Studio ──
STUDIO_DEFAULT_ORGANIZATION=Content Platform
STUDIO_DEFAULT_PROJECT=Content OS

# ── Misc ──
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq
