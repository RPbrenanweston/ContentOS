{
  "name": "contentos",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ContentOS — creation optimizer platform",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test --workspace=packages/ai-core",
    "typecheck": "npm run typecheck --workspace=packages/ai-core",
    "lint": "eslint --no-warn-ignored packages/*/src/**/*.ts",
    "lint:fix": "eslint --fix --no-warn-ignored packages/*/src/**/*.ts",
    "format": "prettier --write 'packages/*/src/**/*.ts'",
    "format:check": "prettier --check 'packages/*/src/**/*.ts'",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "backend/ai_core/**/*.py": [
      "ruff check --fix",
      "ruff format"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.0",
    "prettier": "^3.8.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^1.6.0"
  }
}
