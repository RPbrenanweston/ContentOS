# =============================================================
# Typebot — Coolify Environment Variables
# =============================================================
# Add these in Coolify UI: Service → Environment Variables
# Coolify auto-generates SERVICE_FQDN_* — you just set the
# domains in the Coolify UI per service.
# =============================================================

# --- Database ---
POSTGRES_DB=typebot
POSTGRES_USER=typebot
POSTGRES_PASSWORD=

# --- Encryption ---
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=

# --- Admin ---
ADMIN_EMAIL=robert@brenanweston.com
DISABLE_SIGNUP=true

# --- SMTP (required for magic link login) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=robert@brenanweston.com
SMTP_PASSWORD=
SMTP_SECURE=false
NEXT_PUBLIC_SMTP_FROM=noreply@brenanweston.com

# --- Google OAuth (optional — leave blank to skip) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- S3 Storage (optional — leave blank to skip) ---
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=typebot
S3_ENDPOINT=
S3_REGION=eu-west-2
