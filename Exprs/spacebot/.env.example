# =============================================================
# Spacebot — Coolify Environment Variables
# =============================================================

# --- LLM Providers ---
# At minimum you need ONE provider key. Anthropic is the default.
ANTHROPIC_API_KEY=sk-ant-XXXX
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Model Configuration ---
# Format: provider/model-name
# Spacebot routes by: channel (conversational) vs worker (tasks)
#
# LOW-COST RECOMMENDED SETUP:
# Channel = what users interact with (needs to be good, not expensive)
# Worker  = background tasks like summarisation, profiling (cheap + fast)
#
# Option A: Anthropic only (simplest, one API key)
SPACEBOT_CHANNEL_MODEL=anthropic/claude-sonnet-4-20250514
SPACEBOT_WORKER_MODEL=anthropic/claude-haiku-4-5-20251001
#
# Option B: OpenRouter (access to all models, pay-per-token)
# SPACEBOT_CHANNEL_MODEL=openrouter/anthropic/claude-sonnet-4-20250514
# SPACEBOT_WORKER_MODEL=openrouter/google/gemini-2.0-flash
#
# Option C: Mixed (cheapest possible workers)
# SPACEBOT_CHANNEL_MODEL=anthropic/claude-sonnet-4-20250514
# SPACEBOT_WORKER_MODEL=openrouter/google/gemini-2.0-flash

# --- Bot Integrations ---
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- Search ---
BRAVE_SEARCH_API_KEY=

# =============================================================
# COST COMPARISON (approximate per 1M tokens)
# =============================================================
# anthropic/claude-sonnet-4    $3 in / $15 out   — great quality
# anthropic/claude-haiku-4-5   $0.80 in / $4 out — fast + cheap
# openrouter/google/gemini-2.0-flash  $0.10 in / $0.40 out — dirt cheap workers
# openrouter/deepseek/deepseek-chat   $0.14 in / $0.28 out — great for code
#
# DO NOT USE: nano-gpt/x-ai/grok-4-fast (invalid model ID)
# =============================================================
