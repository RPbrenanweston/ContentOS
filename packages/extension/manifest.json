{
  "manifest_version": 3,
  "name": "ContentOS Capture",
  "version": "0.0.1",
  "description": "Save the current page to ContentOS",
  "permissions": ["activeTab", "storage", "scripting", "notifications"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Save to ContentOS"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "commands": {
    "capture-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current tab to ContentOS"
    }
  },
  "icons": {
    "16": "src/icons/16.png",
    "48": "src/icons/48.png",
    "128": "src/icons/128.png"
  }
}
